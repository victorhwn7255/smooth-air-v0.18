{
  "meta": {
    "name": "Slock Neo-Brutalist",
    "version": "3.0-verified",
    "description": "A playful neo-brutalist design system derived from Slock.ai \u2014 the human-AI collaboration platform. Bold yellow chrome, multi-accent palette (pink, cyan, lavender, salmon), thick black borders, flat opaque surfaces, pixel-art avatars, and a warm cream canvas. The UI splits personality (sidebar/chrome) from productivity (content zone).",
    "mood_keywords": [
      "playful",
      "retro-digital",
      "lo-fi cozy",
      "irreverent",
      "bold",
      "collaborative"
    ],
    "style_references": [
      "neo-brutalism",
      "indie web",
      "pixel-art nostalgia",
      "Memphis design",
      "Tamagotchi UI",
      "Gumroad aesthetic"
    ],
    "design_principles": [
      "Loud chrome, quiet workspace \u2014 sidebar and nav carry all brand energy; content stays readable on warm cream",
      "Borders over shadows \u2014 2px black outlines define every surface; hard-offset shadows only for elevation",
      "Maximum saturation, minimal palette \u2014 each accent has one job (pink=active, cyan=create, lavender=reference, salmon=thread)",
      "Flat is a feature \u2014 zero depth hierarchy; color and borders differentiate, not blur or gradients",
      "Pixel soul \u2014 pixel-art avatars and chunky geometry give the UI character that flat color alone cannot"
    ]
  },
