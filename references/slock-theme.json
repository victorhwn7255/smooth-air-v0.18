  "radius": {
    "none": "0px",
    "sm": "0px",
    "md": "0px",
    "lg": "0px",
    "xl": "0px",
    "full": "9999px",
    "note": "Slock uses 0px border-radius universally. The sharp corners are a defining brutalist trait. Only use full (9999px) for circular indicators like online dots."
  },
  "borders": {
    "note": "Slock uses 2px solid black universally. No thin/medium/subtle variants found in production.",
    "default": "2px solid #000000",
    "thick": "2px solid #000000",
    "medium": "2px solid #000000",
    "thin": "2px solid #000000",
    "accent_left_salmon": "3px solid #F4845F",
    "accent_left_pink": "3px solid #FF6B9D",
    "focus_ring": "2px solid #FF6B9D"
  },
  "shadows": {
    "note": "Slock uses exactly ONE shadow: 2px 2px hard-offset black. No size variants in production.",
    "none": "none",
    "default": "2px 2px 0px 0px #000000",
    "sm": "2px 2px 0px 0px #000000",
    "md": "2px 2px 0px 0px #000000",
    "lg": "2px 2px 0px 0px #000000",
    "xl": "2px 2px 0px 0px #000000"
  },
  "motion": {
    "durations": {
      "instant": "50ms",
      "fast": "100ms",
      "normal": "180ms",
      "slow": "300ms",
      "page": "250ms"
    },
    "easing": {
      "default": "cubic-bezier(0.22, 1, 0.36, 1)",
      "bounce": "cubic-bezier(0.34, 1.56, 0.64, 1)",
      "snap": "cubic-bezier(0, 0, 0.2, 1)",
      "retro_steps": "steps(4, end)"
    },
    "guidelines": {
      "hover": "Instant color swap (50ms) \u2014 yellow\u2192pink for nav, white\u2192cream for cards. No opacity fades.",
      "active_press": "scale(0.97) + translate shadow to zero in 50ms (stamp press effect)",
      "focus": "2px pink border ring, no glow, no blur",
      "modal_enter": "Slide up 180ms with default easing, overlay fades in 120ms",
      "modal_exit": "Fade out 100ms",
      "panel_slide": "Slide from right 180ms with default easing (profile/detail panels)",
      "page_transition": "Instant cut preferred; if animated, 180ms slide-left",
      "skeleton_loading": "Pulse between surface_cream and surface_alt, 1.2s ease-in-out loop",
      "search_highlight": "Instant yellow background on match, no animation",
      "reduce_motion": "Disable all transforms; keep instant color swaps; skeleton becomes static"
    }
  },
  "components": {
    "button": {
      "base": {
        "font_family": "'Space Grotesk', system-ui, sans-serif",
        "font_weight": 700,
        "font_size": "18px",
        "radius": "0px",
        "border": "2px solid #000000",
