          "transform": "translate(2px, 2px)"
        }
      },
      "secondary": {
        "background": "#FFFFFF",
        "color": "#000000",
        "shadow": "2px 2px 0px 0px #000000",
        "hover": {
          "background": "#FFF4CC"
        },
        "active": {
          "shadow": "none",
          "transform": "translate(2px, 2px)"
        }
      },
      "ghost": {
