        "background": "#000000",
        "color": "#FFD700",
        "shadow": "2px 2px 0px 0px #000000",
        "hover": {
          "background": "#FF6B9D",
          "shadow": "2px 2px 0px 0px #000000",
          "transform": "translate(-1px, -1px)"
        },
        "active": {
          "shadow": "none",
          "transform": "translate(2px, 2px)"
        }
      },
      "create": {
        "background": "#5BC0EB",
        "color": "#000000",
        "shadow": "2px 2px 0px 0px #000000",
        "hover": {
          "background": "#4AAFDA",
          "shadow": "2px 2px 0px 0px #000000"
        },
